{
  "title": "MatchSense - Live Match",
  "uid": "matchsense-live",
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "title": "Events Received (by type)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(event_api_events_received_total[1m])",
          "legendFormat": "{{event_type}}"
        }
      ]
    },
    {
      "title": "Events Published Total",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "event_api_events_published_total" }
      ]
    },
    {
      "title": "Kafka Publish Errors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "event_api_publish_errors_total" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Kafka Publish Latency (p95)",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 4 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(event_api_publish_duration_seconds_bucket[5m]))" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      }
    },
    {
      "title": "ML Predictions Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(ml_predictor_predictions_total[1m])",
          "legendFormat": "{{model_type}}"
        }
      ]
    },
    {
      "title": "Home Win Probability",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "ml_predictor_home_win_prob" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.3 },
              { "color": "green", "value": 0.6 }
            ]
          }
        }
      }
    },
    {
      "title": "Last xG Value",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "ml_predictor_last_xg" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "blue", "value": 0 },
              { "color": "yellow", "value": 0.15 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      }
    },
    {
      "title": "ML Prediction Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(ml_predictor_prediction_duration_seconds_bucket[5m]))",
          "legendFormat": "{{model_type}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Query API Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(query_api_query_duration_seconds_bucket[5m]))",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Kafka Messages Processed (ML)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 24 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "ml_predictor_kafka_messages_total" }
      ]
    },
    {
      "title": "Active Matches",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 24 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "query_api_active_matches" }
      ]
    },
    {
      "title": "HTTP Requests by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(event_api_http_requests_total[1m])",
          "legendFormat": "event-api {{status}}"
        },
        {
          "expr": "rate(query_api_http_requests_total[1m])",
          "legendFormat": "query-api {{status}}"
        }
      ]
    }
  ],
  "schemaVersion": 39
}